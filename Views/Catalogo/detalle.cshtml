@model Catalogo.Models.Item

@{
    ViewData["Title"] = "Detalle - " + Model.Titulo;
}

<div class="container mt-5">
    <h1 class="detail-title">@Model.Titulo</h1>

    <div class="detail-info-box shadow-lg">
        <div class="row text-center">
            <div class="col-md-4 border-md-end border-secondary mb-4 mb-md-0">
                <span class="detail-label">Género</span>
                <strong>@Model.Genero</strong>
            </div>
            <div class="col-md-4 border-md-end border-secondary mb-4 mb-md-0">
                <span class="detail-label">Consola</span>
                <strong>@Model.Consola</strong>
            </div>
            <div class="col-md-4">
                <span class="detail-label">Lanzamiento</span>
                <strong>@Model.Ano</strong>
            </div>
        </div>

        <hr class="border-secondary my-4">

        <div class="px-3">
            <span class="detail-label">Sinopsis / Descripción</span>
            <p class="mt-3 text-white-50" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important; font-size: 1.1rem; line-height: 1.6;">
                @Model.Descripcion
            </p>
        </div>
    </div>

    <div class="text-center mt-5">
        <a asp-action="Index" class="btn btn-outline-light px-5 py-2" style="border-radius: 50px;">
            ← Volver al Catálogo
        </a>
    </div>
</div>